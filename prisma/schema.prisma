generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model PopupSettings {
  id            String   @id @default(cuid())
  shop          String   @unique
  title         String   @default("Welcome to our store!")
  message       String   @default("Get 10% off your first order. Use code WELCOME10")
  buttonText    String   @default("Shop Now!")
  textAlign     String   @default("left")
  titleSize     String   @default("22")
  messageSize   String   @default("16")
  titleColor    String   @default("#ffffff")
  messageColor  String   @default("#4a5568")
  fontFamily    String   @default("inherit")
  liquidGlass   Boolean  @default(false)
  isActive      Boolean  @default(true)
  colorStart       String   @default("#667eea")
  colorEnd         String   @default("#764ba2")
  buttonTextColor  String   @default("#ffffff")
  glassGradient    Boolean? @default(false)
  promoCode        String?  @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BannerSettings {
  id               String   @id
  shop             String   @unique
  isActive         Boolean  @default(true)
  position         String   @default("top")
  bgColor          String   @default("#000000")
  textColor        String   @default("#ffffff")
  languages        String   @default("en,fr,es,de,it,pt,nl,ja,zh,ar")
  showFlags        Boolean  @default(false)
  autoRedirect     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  showBanner       Boolean  @default(false)
  showFloating     Boolean  @default(false)
  flagShape        String   @default("round")
  plan             String   @default("free")
  mobileBanner     Boolean  @default(false)
  mobileFloating   Boolean  @default(false)
  defaultLang      String   @default("en")
  bannerText       String   @default("")
  mobileBannerText String   @default("")
}
