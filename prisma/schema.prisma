generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model PopupSettings {
  id          String   @id @default(cuid())
  shop        String   @unique
  title       String   @default("Welcome to our store!")
  message     String   @default("Get 10% off your first order. Use code WELCOME10")
  isActive    Boolean  @default(true)
  colorStart  String   @default("#667eea")
  colorEnd    String   @default("#764ba2")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
