{% comment %} popup-pop SAFE v6 {% endcomment %}

<div
  id="popup-pop-overlay"
  class="popup-pop-overlay"
  data-app-url="https://popup-pop.vercel.app"
>
  <div class="popup-pop-modal" role="dialog" aria-modal="true" aria-labelledby="popup-pop-title">

    <button class="popup-pop-close" id="popup-pop-close" type="button" aria-label="Close popup">
      ×
    </button>

    <div class="popup-pop-header">
      <h2 class="popup-pop-title" id="popup-pop-title">
        {{ block.settings.popup_title | default: "Welcome to our store!" }}
      </h2>
    </div>

    <div class="popup-pop-body">
      <p class="popup-pop-message">
        {{ block.settings.popup_message | default: "Get 10% off your first order. Use code WELCOME10" }}
      </p>
    </div>

    <div class="popup-pop-footer">
      <button class="popup-pop-button" id="popup-pop-cta" type="button">
        {{ block.settings.button_text | default: "Shop Now!" }}
      </button>
    </div>

  </div>
</div>

<style>
  .popup-pop-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 99999;

    display: none;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
  }

  .popup-pop-overlay.is-active {
    display: flex;
  }

  .popup-pop-modal {
    background: #fff;
    border-radius: 16px;
    max-width: 480px;
    width: 90%;
    position: relative;
    box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    overflow: hidden;
  }

  .popup-pop-header {
    padding: 32px;
    background: linear-gradient(135deg, {{ block.settings.color_start | default: "#667eea" }}, {{ block.settings.color_end | default: "#764ba2" }});
  }

  .popup-pop-title {
    color: #fff;
    margin: 0;
    font-size: 22px;
  }

  .popup-pop-body {
    padding: 24px 32px;
  }

  .popup-pop-message {
    margin: 0;
    color: #4a5568;
  }

  .popup-pop-footer {
    padding: 0 32px 32px;
  }

  .popup-pop-button {
    width: 100%;
    padding: 12px;
    border: 0;
    border-radius: 8px;
    background: linear-gradient(135deg, {{ block.settings.color_start | default: "#667eea" }}, {{ block.settings.color_end | default: "#764ba2" }});
    color: #fff;
    font-weight: 600;
    cursor: pointer;
  }

  .popup-pop-close {
    position: absolute;
    top: 10px;
    right: 14px;
    background: transparent;
    border: 0;
    font-size: 26px;
    cursor: pointer;
    color: #fff;
  }
</style>

<script>
(function () {
  function init() {
    const overlay = document.getElementById('popup-pop-overlay');
    if (!overlay) return;

    const closeBtn = document.getElementById('popup-pop-close');
    const ctaBtn = document.getElementById('popup-pop-cta');

    function openPopup() {
      overlay.classList.add('is-active');
    }

    function closePopup() {
      overlay.classList.remove('is-active');
    }

    // events (SAFE)
    closeBtn?.addEventListener('click', closePopup);
    ctaBtn?.addEventListener('click', closePopup);

    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closePopup();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closePopup();
    });

    // ALWAYS show after load delay (review-safe)
    setTimeout(openPopup, 1200);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% schema %}
{
  "name": "Popup Pop",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "popup_title",
      "label": "Title",
      "default": "Welcome to our store!"
    },
    {
      "type": "textarea",
      "id": "popup_message",
      "label": "Message",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button",
      "default": "Shop now"
    },
    {
      "type": "select",
      "id": "color_start",
      "label": "Start color",
      "default": "#667eea",
      "options": [
        { "value": "#667eea", "label": "Purple" },
        { "value": "#f093fb", "label": "Pink" },
        { "value": "#4facfe", "label": "Blue" }
      ]
    },
    {
      "type": "select",
      "id": "color_end",
      "label": "End color",
      "default": "#764ba2",
      "options": [
        { "value": "#764ba2", "label": "Purple dark" },
        { "value": "#f5576c", "label": "Red" },
        { "value": "#00f2fe", "label": "Cyan" }
      ]
    }
  ]
}
{% endschema %}