{% comment %} popup-pop v6.0 {% endcomment %}
<div id="popup-pop-overlay" data-app-url="https://popup-pop.vercel.app" data-popup-block="{{ block.id }}">
  <div id="popup-pop-modal">
    <button id="popup-pop-close" type="button" aria-label="Close">&#x2715;</button>
    <div id="popup-pop-header">
      <h2 id="popup-pop-title">Welcome to our store!</h2>
    </div>
    <div id="popup-pop-body">
      <p id="popup-pop-message">Get 10% off your first order. Use code WELCOME10</p>
    </div>
    <div id="popup-pop-footer">
      <button id="popup-pop-cta" type="button">Shop Now!</button>
    </div>
  </div>
</div>

<style>
  #popup-pop-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 2147483647;
    align-items: center;
    justify-content: center;
  }

  /* Overlay liquid glass : quasi invisible */
  #popup-pop-overlay.liquid-glass {
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  #popup-pop-modal {
    background: #fff;
    border-radius: 16px;
    max-width: 480px;
    width: 90%;
    position: relative;
    box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    overflow: hidden;
  }
  #popup-pop-header {
    padding: 32px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  #popup-pop-title {
    color: #fff;
    margin: 0;
    font-size: 22px;
    font-weight: 700;
  }
  #popup-pop-body {
    padding: 24px 32px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  #popup-pop-message {
    margin: 0;
    color: #4a5568;
    font-size: 16px;
    line-height: 1.6;
  }
  #popup-pop-footer { padding: 20px 32px 28px; }
  #popup-pop-cta {
    width: 100%; padding: 14px; border: 0; border-radius: 8px; cursor: pointer;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff; font-size: 16px; font-weight: 600;
  }
  #popup-pop-close {
    position: absolute; top: 10px; right: 14px;
    background: rgba(255,255,255,0.25); border: 0;
    color: #fff; font-size: 20px; cursor: pointer;
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    z-index: 10;
  }
  #popup-pop-close:hover { background: rgba(255,255,255,0.45); }

  /* ── Liquid Glass : modal blanche lumineuse ── */
  #popup-pop-modal.liquid-glass {
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(36px) saturate(200%) brightness(1.08);
    -webkit-backdrop-filter: blur(36px) saturate(200%) brightness(1.08);
    border: 1px solid rgba(255,255,255,0.90);
    border-radius: 28px;
    overflow: visible;
    box-shadow:
      0 0 0 0.5px rgba(255,255,255,0.80) inset,
      0 2px 6px rgba(255,255,255,0.60) inset,
      0 20px 60px rgba(0,0,0,0.10),
      0 4px 16px rgba(0,0,0,0.06);
  }
  #popup-pop-modal.liquid-glass::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    border-radius: 28px 28px 0 0;
    background: linear-gradient(90deg,
      transparent 0%, rgba(255,255,255,0.95) 30%,
      white 50%, rgba(255,255,255,0.95) 70%, transparent 100%);
    z-index: 1;
  }
  #popup-pop-modal.liquid-glass::after {
    content: ''; position: absolute; inset: 0; border-radius: 28px;
    background: linear-gradient(160deg,
      rgba(255,255,255,0.55) 0%,
      rgba(255,255,255,0.15) 45%,
      rgba(255,255,255,0.30) 100%);
    pointer-events: none; z-index: 0;
  }

  /* Header glass par défaut : blanc transparent */
  #popup-pop-modal.liquid-glass #popup-pop-header {
    background: rgba(255,255,255,0.45);
    border-bottom: 1px solid rgba(255,255,255,0.70);
    border-radius: 28px 28px 0 0;
    position: relative; z-index: 2;
  }

  /* Header glass avec gradient activé — appliqué via JS */
  #popup-pop-modal.liquid-glass #popup-pop-header.has-gradient {
    border-bottom: 1px solid rgba(255,255,255,0.30);
    border-radius: 28px 28px 0 0;
    position: relative; z-index: 2;
  }

  #popup-pop-modal.liquid-glass #popup-pop-body {
    background: rgba(255,255,255,0.25);
    border-bottom: 1px solid rgba(255,255,255,0.55);
    position: relative; z-index: 2;
  }
  #popup-pop-modal.liquid-glass #popup-pop-footer {
    background: rgba(255,255,255,0.20);
    border-radius: 0 0 28px 28px;
    position: relative; z-index: 2;
  }

  /* Bouton CTA glass */
  #popup-pop-modal.liquid-glass #popup-pop-cta {
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.85);
    border-radius: 14px;
    color: #1a1a2e;
    box-shadow:
      0 1px 3px rgba(255,255,255,0.80) inset,
      0 4px 12px rgba(0,0,0,0.06);
    transition: background 0.2s ease;
  }
  #popup-pop-modal.liquid-glass #popup-pop-cta:hover {
    background: rgba(255,255,255,0.72);
  }

  /* Bouton fermer glass */
  #popup-pop-modal.liquid-glass #popup-pop-close {
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.80);
    color: #555;
  }
  #popup-pop-modal.liquid-glass #popup-pop-close:hover {
    background: rgba(255,255,255,0.78);
  }

  @media(max-width:480px) {
    #popup-pop-header, #popup-pop-body, #popup-pop-footer { padding-left:20px; padding-right:20px; }
  }
</style>

<script>
/* popup-pop-v6.0 */
(function() {
  var overlay  = document.getElementById('popup-pop-overlay');
  if (!overlay) return;

  var appUrl = overlay.getAttribute('data-app-url') || 'https://popup-pop.vercel.app';
  var KEY    = 'popup_pop_shown_' + (overlay.getAttribute('data-popup-block') || 'default');
  if (sessionStorage.getItem(KEY)) return;

  var shop     = (window.Shopify && window.Shopify.shop) ? window.Shopify.shop : location.hostname;
  var closeBtn = document.getElementById('popup-pop-close');
  var titleEl  = document.getElementById('popup-pop-title');
  var msgEl    = document.getElementById('popup-pop-message');
  var headerEl = document.getElementById('popup-pop-header');
  var ctaEl    = document.getElementById('popup-pop-cta');
  var modal    = document.getElementById('popup-pop-modal');

  function show() { overlay.style.display = 'flex'; sessionStorage.setItem(KEY, '1'); }
  function hide() { overlay.style.display = 'none'; }

  closeBtn.onclick = function() { hide(); };
  ctaEl.onclick    = function() { hide(); };
  overlay.onclick  = function(e) { if (e.target === overlay) hide(); };
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') hide(); });

  fetch(appUrl + '/api/popup-settings?shop=' + shop)
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.active) return;

      /* Content */
      if (d.title)      titleEl.textContent = d.title;
      if (d.message)    msgEl.textContent   = d.message;
      if (d.buttonText) ctaEl.textContent   = d.buttonText;

      /* Typography */
      if (d.fontFamily && d.fontFamily !== 'inherit') {
        var googleFonts = ['Inter','Playfair Display','Montserrat','Lato','Poppins'];
        var fontName = googleFonts.find(function(f) { return d.fontFamily.indexOf(f) !== -1; });
        if (fontName) {
          var link = document.createElement('link');
          link.rel  = 'stylesheet';
          link.href = 'https://fonts.googleapis.com/css2?family=' + fontName.replace(/ /g, '+') + ':wght@400;600;700&display=swap';
          document.head.appendChild(link);
        }
        modal.style.fontFamily   = d.fontFamily;
        titleEl.style.fontFamily = d.fontFamily;
        msgEl.style.fontFamily   = d.fontFamily;
        ctaEl.style.fontFamily   = d.fontFamily;
      }

      if (d.textAlign) {
        titleEl.style.textAlign = d.textAlign;
        msgEl.style.textAlign   = d.textAlign;
      }
      if (d.titleSize)   titleEl.style.fontSize = d.titleSize + 'px';
      if (d.messageSize) msgEl.style.fontSize   = d.messageSize + 'px';

      /* Text colors */
      if (d.titleColor)   titleEl.style.color = d.titleColor;
      if (d.messageColor) msgEl.style.color   = d.messageColor;

      if (d.liquidGlass) {
        overlay.classList.add('liquid-glass');
        modal.classList.add('liquid-glass');

        if (d.glassGradient && d.colorStart && d.colorEnd) {
          /* Gradient plein sur header ET bouton + effet glass par dessus, body/footer restent transparents */
          var g = 'linear-gradient(135deg,' + d.colorStart + ' 0%,' + d.colorEnd + ' 100%)';
          headerEl.classList.add('has-gradient');
          headerEl.style.background = g;
          ctaEl.style.background    = g;
          /* Texte blanc sur gradient coloré */
          if (!d.titleColor) titleEl.style.color = '#fff';
        } else {
          /* Header blanc transparent, texte sombre */
          if (!d.titleColor) titleEl.style.color = '#1a1a2e';
        }

        if (!d.messageColor) msgEl.style.color = '#2d3748';

      } else {
        /* Mode normal : gradient plein partout */
        if (d.colorStart && d.colorEnd) {
          var g = 'linear-gradient(135deg,' + d.colorStart + ',' + d.colorEnd + ')';
          headerEl.style.background = g;
          ctaEl.style.background    = g;
        }
      }

      /* Couleur texte du bouton */
      if (d.buttonTextColor) ctaEl.style.color = d.buttonTextColor;

      setTimeout(show, 1200);
    })
    .catch(function() { setTimeout(show, 1200); });
})();
</script>

{% schema %}
{
  "name": "Popup Pop",
  "target": "body",
  "settings": []
}
{% endschema %}
