{% comment %}
  Popup Pop - Theme App Extension Block
  - Titre/message synchronisés depuis l'app admin (DB)
  - Fallback sur les settings du bloc si l'API est indisponible
  - Couleurs personnalisables dans le customizer
{% endcomment %}

{% if block.settings.popup_enabled %}
  <div
    id="popup-pop-overlay"
    class="popup-pop-overlay"
    data-popup-block="{{ block.id }}"
    data-app-url="{{ block.settings.app_url | default: 'https://popup-pop.vercel.app' }}"
    data-fallback-title="{{ block.settings.popup_title | escape }}"
    data-fallback-message="{{ block.settings.popup_message | escape }}"
    data-fallback-button="{{ block.settings.button_text | escape }}"
    style="display: none;"
  >
    <div class="popup-pop-modal" role="dialog" aria-modal="true" aria-labelledby="popup-pop-title">
      <button class="popup-pop-close" id="popup-pop-close" aria-label="Close popup" type="button">
        &times;
      </button>
      <div class="popup-pop-header">
        <h2 class="popup-pop-title" id="popup-pop-title">
          {{ block.settings.popup_title | default: "Welcome to our store!" }}
        </h2>
      </div>
      <div class="popup-pop-body">
        <p class="popup-pop-message">
          {{ block.settings.popup_message | default: "Get 10% off your first order. Use code WELCOME10" }}
        </p>
      </div>
      <div class="popup-pop-footer">
        <button class="popup-pop-button" id="popup-pop-cta" type="button">
          {{ block.settings.button_text | default: "Shop Now" }}
        </button>
      </div>
    </div>
  </div>

  <style>
    .popup-pop-overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.6);
      z-index: 99999;
      display: flex !important;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(4px);
      animation: ppFadeIn 0.3s ease;
    }
    .popup-pop-overlay.hidden { display: none !important; }

    @keyframes ppFadeIn {
      from { opacity: 0; } to { opacity: 1; }
    }
    @keyframes ppSlideUp {
      from { opacity: 0; transform: translateY(30px) scale(0.95); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .popup-pop-modal {
      background: #ffffff;
      border-radius: 16px;
      max-width: 480px;
      width: 90%;
      position: relative;
      box-shadow: 0 25px 60px rgba(0,0,0,0.3);
      animation: ppSlideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
      overflow: hidden;
    }

    .popup-pop-header {
      background: linear-gradient(135deg, {{ block.settings.color_start | default: "#667eea" }} 0%, {{ block.settings.color_end | default: "#764ba2" }} 100%);
      padding: 32px 32px 24px;
    }

    .popup-pop-title {
      color: #ffffff;
      font-size: 24px;
      font-weight: 700;
      margin: 0;
      line-height: 1.3;
    }

    .popup-pop-body { padding: 24px 32px; }

    .popup-pop-message {
      color: #4a5568;
      font-size: 16px;
      line-height: 1.6;
      margin: 0;
    }

    .popup-pop-footer { padding: 8px 32px 32px; }

    .popup-pop-button {
      display: block;
      width: 100%;
      padding: 14px 24px;
      background: linear-gradient(135deg, {{ block.settings.color_start | default: "#667eea" }} 0%, {{ block.settings.color_end | default: "#764ba2" }} 100%);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .popup-pop-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    .popup-pop-close {
      position: absolute;
      top: 12px; right: 16px;
      background: rgba(255,255,255,0.2);
      border: none;
      color: #fff;
      font-size: 24px;
      cursor: pointer;
      width: 32px; height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s ease;
      z-index: 1;
    }
    .popup-pop-close:hover { background: rgba(255,255,255,0.35); }

    @media (max-width: 480px) {
      .popup-pop-modal { width: 95%; margin: 16px; }
      .popup-pop-title { font-size: 20px; }
      .popup-pop-header, .popup-pop-body, .popup-pop-footer {
        padding-left: 20px; padding-right: 20px;
      }
    }
  </style>

  <script>
    (function() {
      var KEY = 'popup_pop_shown_{{ block.id }}';
      var overlay = document.getElementById('popup-pop-overlay');
      var closeBtn = document.getElementById('popup-pop-close');
      var ctaBtn = document.getElementById('popup-pop-cta');
      var titleEl = overlay ? overlay.querySelector('.popup-pop-title') : null;
      var messageEl = overlay ? overlay.querySelector('.popup-pop-message') : null;
      var shop = window.Shopify && window.Shopify.shop ? window.Shopify.shop : location.hostname;
      var appUrl = overlay ? overlay.getAttribute('data-app-url') : 'https://popup-pop.vercel.app';

      if (sessionStorage.getItem(KEY)) return;

      // ✅ Récupère le titre/message/couleurs depuis l'app admin (DB)
      fetch(appUrl + '/api/popup-settings?shop=' + shop)
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (!data.active) return; // popup désactivé depuis l'admin
          if (data.title && titleEl) titleEl.textContent = data.title;
          if (data.message && messageEl) messageEl.textContent = data.message;
          if (data.colorStart && data.colorEnd) {
            var gradient = 'linear-gradient(135deg, ' + data.colorStart + ' 0%, ' + data.colorEnd + ' 100%)';
            var header = overlay.querySelector('.popup-pop-header');
            var btn = overlay.querySelector('.popup-pop-button');
            if (header) header.style.background = gradient;
            if (btn) btn.style.background = gradient;
          }
          setTimeout(show, 1500);
        })
        .catch(function() {
          // Fallback : utilise les settings du bloc thème
          setTimeout(show, 1500);
        });

      function show() {
        if (overlay) {
          overlay.style.display = 'flex';
          overlay.classList.remove('hidden');
          sessionStorage.setItem(KEY, '1');
        }
      }

      function hide() {
        if (overlay) {
          overlay.classList.add('hidden');
          overlay.style.display = 'none';
        }
      }

      if (closeBtn) closeBtn.addEventListener('click', hide);
      if (ctaBtn) ctaBtn.addEventListener('click', hide);
      if (overlay) overlay.addEventListener('click', function(e) {
        if (e.target === overlay) hide();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') hide();
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Popup Pop",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "popup_enabled",
      "label": "Enable Popup",
      "default": true
    },
    {
      "type": "text",
      "id": "popup_title",
      "label": "Popup Title (fallback)",
      "info": "Used if the app admin is unavailable. Set your main title in the Popup Pop app.",
      "default": "Welcome to our store!"
    },
    {
      "type": "textarea",
      "id": "popup_message",
      "label": "Popup Message (fallback)",
      "info": "Used if the app admin is unavailable. Set your main message in the Popup Pop app.",
      "default": "Get 10% off your first order. Use code WELCOME10"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_start",
      "label": "Gradient Start Color",
      "default": "#667eea",
      "options": [
        { "value": "#667eea", "label": "Purple Blue" },
        { "value": "#f093fb", "label": "Pink" },
        { "value": "#4facfe", "label": "Sky Blue" },
        { "value": "#43e97b", "label": "Green" },
        { "value": "#fa709a", "label": "Rose" },
        { "value": "#f7971e", "label": "Orange" },
        { "value": "#000000", "label": "Black" },
        { "value": "#1a1a2e", "label": "Dark Navy" }
      ]
    },
    {
      "type": "select",
      "id": "color_end",
      "label": "Gradient End Color",
      "default": "#764ba2",
      "options": [
        { "value": "#764ba2", "label": "Deep Purple" },
        { "value": "#f5576c", "label": "Coral Red" },
        { "value": "#00f2fe", "label": "Cyan" },
        { "value": "#38f9d7", "label": "Teal" },
        { "value": "#ee0979", "label": "Hot Pink" },
        { "value": "#ff512f", "label": "Warm Red" },
        { "value": "#434343", "label": "Dark Grey" },
        { "value": "#16213e", "label": "Midnight Blue" }
      ]
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://popup-pop.vercel.app",
      "info": "Do not modify this field."
    }
  ]
}
{% endschema %}

